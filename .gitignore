.env

# Local operator notes (host-specific, not version-controlled)
AGENTS_MEMO.md
configs/base/STORAGE_RELOCATION_*.md

# Local data workspaces (not version-controlled)
# Both forms are needed: trailing-slash patterns do not match symlinks.
data/
tmp/
output/
configs/base/data/
configs/base/tmp/
configs/base/output/
configs/base/data
configs/base/tmp
configs/base/output

# Local scratch configs (official recipes live in configs/profiles/)
configs/base/pipeline-*.yaml

# Stray rasters that land directly in configs/base/ (e.g. interrupted OAM/COG
# fragments); never commit imagery here.
configs/base/*.tif
configs/base/*.tif_*
configs/base/*.tiff

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/
ENV/

.coverage
